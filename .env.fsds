# FSDS integration mode — set to 'true' when deployed as FSDS iframe
VITE_FSDS_MODE=false

# FSDS API base URL — the backend endpoint for /slides/* APIs
VITE_FSDS_API_BASE_URL=http://localhost:3002

# Allowed parent origins for postMessage validation (comma-separated)
# Supports wildcard subdomains: https://*.example.com
VITE_ALLOWED_PARENT_ORIGINS=http://localhost:3000,http://acme.local:3000

# Base path for production build (e.g. '/slides-editor/')
VITE_BASE_PATH=/slides-editor/
